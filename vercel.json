{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/operacion", "destination": "/operacion.html" },
    { "source": "/riesgo", "destination": "/riesgo.html" },
    { "source": "/cliente", "destination": "/cliente.html" },
    { "source": "/nosotros", "destination": "/nosotros.html" },
    { "source": "/contacto", "destination": "/contacto.html" },
    { "source": "/recursos", "destination": "/recursos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
